          "name": "Device name (empty = auto-detect from sysName)",
          "scan_interval": "Poll interval (seconds)"
        },
        "data_description": {
          "community_write": "Leave empty for read-only access. When set, port switches and SET services are enabled.",
          "scan_interval": "How often should HA poll the switch? Minimum 10 seconds."
        }
      }
    },
    "error": {
      "cannot_connect": "Connection failed – host unreachable or SNMP not enabled",
      "invalid_auth": "Invalid community string",
      "unknown": "Unknown error – check logs"
    },
    "abort": {
      "already_configured": "This switch is already configured"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "SNMP Switch Options",
        "data": {
          "scan_interval": "Poll interval (seconds)",
          "community_write": "Community String (Write)"
        }
      }
    }
  },
  "services": {
    "set_port_alias": {
      "name": "Set Port Alias",
      "description": "Sets the ifAlias of a port.",
      "fields": {
        "entry_id": {"name": "Entry ID", "description": "Entry ID of the SNMP Switch integration"},
