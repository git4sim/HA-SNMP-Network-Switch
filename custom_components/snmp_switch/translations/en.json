    "set_sys_location": {
      "name": "Set System Location",
      "description": "Sets sysLocation on the switch.",
      "fields": {
        "entry_id": {"name": "Entry ID", "description": "Entry ID"},
        "location": {"name": "Location", "description": "Physical installation location"}
